# AutoJobAgent environment template
# Copy to `.env` and fill in your own values.

# ==================== App / Auth ====================
JWT_SECRET=replace-with-a-long-random-secret
APP_ENV=dev
LOG_LEVEL=INFO

# Optional helper value used by some local scripts
APP_PASSWORD=replace-if-needed

# ==================== LLM ====================
# Current default implementation uses Google Gemini
GOOGLE_API_KEY=your-google-gemini-api-key
LLM_MODEL=gemini-3-flash-preview

# Reserved for future provider switching / extensions
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ==================== Email / Notifications ====================
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-app-password
SMTP_FROM_NAME=AutoJobAgent

# ==================== Frontend ====================
VITE_API_BASE_URL=http://localhost:8000

# ==================== Browser / Automation ====================
BROWSER_HEADLESS=1
